# =============================================================
# CryptoArena Environment Variables
# =============================================================

# Execution Mode
EXECUTION_MODE=simulation  # simulation | live

# On-Chain (Base L2)
BASE_RPC_URL=https://mainnet.base.org
LEADERBOARD_CONTRACT=  # deployed contract address
DEPLOYER_PRIVATE_KEY=  # KEEP SECRET — only for testnet/demo

# Binance API (for live mode ONLY)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CoinGecko (optional — for higher rate limits)
COINGECKO_API_KEY=

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# Redis (optional — for distributed state)
REDIS_URL=redis://localhost:6379/0
